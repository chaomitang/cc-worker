# Anthropic-compatible API (your gateway or api.anthropic.com)
# .env is loaded automatically on startup (src/loadEnv.ts)
ANTHROPIC_BASE_URL=https://your-gateway.example.com
ANTHROPIC_API_KEY=your-api-key
# Optional: hide /login prompt when using API key only
# DISABLE_LOGIN_COMMAND=1
# Or bearer token style:
# ANTHROPIC_AUTH_TOKEN=your-token

# Default model for each session (any ID your endpoint accepts)
ANTHROPIC_MODEL=sonnet

# Map built-in aliases to your gateway model IDs (optional)
# ANTHROPIC_DEFAULT_SONNET_MODEL=your-sonnet-model
# ANTHROPIC_DEFAULT_OPUS_MODEL=your-opus-model
# ANTHROPIC_DEFAULT_HAIKU_MODEL=your-haiku-model
# CLAUDE_CODE_SUBAGENT_MODEL=your-main-model

# Discover models from gateway GET /v1/models (IDs must start with claude or anthropic)
# CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1

# Non-anthropic.com hosts: re-enable MCP tool search if your proxy forwards tool_reference
# ENABLE_TOOL_SEARCH=true

# Working directory for the agent (defaults to process.cwd())
# CC_WORKER_CWD=/path/to/project

# Persisted data: chat history, token usage (.data/chats, .data/usage)
# CC_WORKER_DATA_DIR=/path/to/.data

# Permission mode (query/Web 无 TTY，不要用 default 除非配了交互审批)
# default | acceptEdits | bypassPermissions | dontAsk | auto | plan
# acceptEdits：自动放行 Edit；Write 等仍可能弹权限
# bypassPermissions：需同时 CC_WORKER_ALLOW_DANGEROUS_SKIP=1
CC_WORKER_PERMISSION_MODE=acceptEdits
# CC_WORKER_ALLOW_DANGEROUS_SKIP=1
# CC_WORKER_INTERACTIVE_PERMISSIONS=1   # Web 对话页弹出 Allow/Deny（需 POST /api/chat/permission）

# Path to claude executable if SDK cannot find bundled binary
# CC_WORKER_CLAUDE_EXECUTABLE=/path/to/claude

# Web UI server port (default 3000)
# CC_WORKER_PORT=3000

# WeChat iLink Bot (腾讯官方个人号 Bot API)
# ILINK_ENABLE=1
# ILINK_BOT_TOKEN=your-bot-token-after-qr-login
# ILINK_BASE_URL=https://ilinkai.weixin.qq.com
# ILINK_TOKEN_FILE=.data/ilink-bot-token.json
